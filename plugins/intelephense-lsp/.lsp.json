{
  "php": {
    "command": "/opt/homebrew/bin/intelephense",
    "args": ["--stdio"],
    "extensionToLanguage": {
      ".php": "php",
      ".phtml": "php",
      ".php3": "php",
      ".php4": "php",
      ".php5": "php",
      ".phps": "php"
    },
    "transport": "stdio",
    "initializationOptions": {
      "licenceKey": "${INTELEPHENSE_LICENCE_KEY}"
    },
    "settings": {},
    "maxRestarts": 3,
    "restartOnCrash": true
  }
}
